{
  "name": "@gulu9527/code-trust",
  "version": "0.2.0",
  "description": "AI code trust verification tool — verify AI-generated code with deterministic algorithms",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "code-trust": "dist/cli/index.js",
    "codetrust": "dist/cli/index.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "format": "prettier --write \"src/**/*.ts\"",
    "start": "node dist/cli/index.js",
    "prepublishOnly": "npm run build && npm test"
  },
  "keywords": [
    "ai",
    "code-review",
    "trust",
    "static-analysis",
    "cli",
    "hallucination-detection",
    "code-quality"
  ],
  "author": "CodeTrust Contributors",
  "repository": {
    "type": "git",
    "url": "https://github.com/gulu9527/CodeTrust.git"
  },
  "homepage": "https://github.com/gulu9527/CodeTrust#readme",
  "bugs": {
    "url": "https://github.com/gulu9527/CodeTrust/issues"
  },
  "license": "Apache-2.0",
  "engines": {
    "node": ">=20.0.0"
  },
  "files": [
    "dist",
    "docs",
    "README.md",
    "LICENSE",
    "action.yml"
  ],
  "dependencies": {
    "@typescript-eslint/typescript-estree": "^8.56.1",
    "cli-table3": "^0.6.5",
    "commander": "^14.0.3",
    "cosmiconfig": "^9.0.1",
    "picocolors": "^1.1.1",
    "simple-git": "^3.32.3",
    "typescript": "^5.9.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.3.5",
    "eslint": "^10.0.3",
    "prettier": "^3.8.1",
    "tsup": "^8.5.1",
    "typescript-eslint": "^8.56.1",
    "vitest": "^4.0.18"
  }
}
